# ─────────────────────────────────────────────────────────────
# s3-media-edge — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Garage S3 — Secrets (REQUIRED) ──────────────────────────
# Generate: openssl rand -hex 32
GARAGE_RPC_SECRET=
# Generate: openssl rand -base64 24
GARAGE_ADMIN_TOKEN=
# Generate: openssl rand -base64 24
GARAGE_METRICS_TOKEN=

# ── S3 Credentials (REQUIRED) ──────────────────────────────
# Created automatically on first boot via bootstrap
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Bucket (REQUIRED) ───────────────────────────────────────
S3_BUCKET=my-media

# ── WebUI Auth (recommended) ────────────────────────────────
# Generate: htpasswd -nbBC 10 "admin" "your-password"
# AUTH_USER_PASS=admin:$2y$10$...

# ── Ports (standalone mode) ──────────────────────────────────
# Set to host ports; Coolify users can leave defaults
CDN_PORT=8080
WEBUI_PORT=3909

# ── CDN Config (optional) ───────────────────────────────────
# CDN_DOMAIN=cdn.example.com
# ALLOWED_ORIGINS_REGEX=example\.com|localhost
# CACHE_MAX_SIZE=10g
# MAX_VIDEO_SIZE=50m
# MAX_IMG_SIZE=5m

# ── Image Processing (optional) ─────────────────────────────
# IMAGOR_AUTO_WEBP=1
# IMAGOR_AUTO_AVIF=0
# IMAGOR_PROCESS_CONCURRENCY=10
# IMAGOR_REQUEST_TIMEOUT=30s
# IMAGOR_RESULT_STORAGE_EXPIRATION=720h
