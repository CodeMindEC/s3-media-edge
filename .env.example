# ─────────────────────────────────────────────────────────────
# s3-media-edge — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ── Garage S3 — Secrets (REQUIRED) ──────────────────────────
# Generate RPC secret: openssl rand -hex 32
GARAGE_RPC_SECRET=
# Generate admin token: openssl rand -base64 32
GARAGE_ADMIN_TOKEN=
# Generate metrics token: openssl rand -base64 32
GARAGE_METRICS_TOKEN=

# ── Imagor — S3 Credentials (REQUIRED) ──────────────────────
# Create via: docker compose exec garage /garage key create my-key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Bucket (REQUIRED) ───────────────────────────────────────
# Create via: docker compose exec garage /garage bucket create my-media
S3_BUCKET=my-media

# ── WebUI Auth (recommended) ────────────────────────────────
# Generate: htpasswd -nbBC 10 "admin" "your-password"
# AUTH_USER_PASS=admin:$2y$10$...

# ── CDN Config (optional, sensible defaults) ────────────────
# CDN_DOMAIN=cdn.example.com
# CDN_PORT=8080
# WEBUI_PORT=3909
# ALLOWED_ORIGINS_REGEX=example\.com|localhost
# CACHE_MAX_SIZE=10g
# MAX_VIDEO_SIZE=50m
# MAX_IMG_SIZE=5m

# ── Image Processing (optional) ─────────────────────────────
# IMAGOR_AUTO_WEBP=1
# IMAGOR_AUTO_AVIF=0
# IMAGOR_PROCESS_CONCURRENCY=10
# IMAGOR_REQUEST_TIMEOUT=30s
# IMAGOR_RESULT_STORAGE_EXPIRATION=720h

# ── Versions (optional) ─────────────────────────────────────
# GARAGE_VERSION=v2.1.0
# IMAGOR_VERSION=latest
# WEBUI_VERSION=1.1.0
# RUST_LOG=garage=info
